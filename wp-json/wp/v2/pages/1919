\u0430\u0442\u0430 \u0434\u0438\u0430\u0433\u043d\u043e\u0441\u0442\u0438\u043a\u0430 \u0435 \u043e\u0442 \u0441\u044a\u0449\u0435\u0441\u0442\u0432\u0435\u043d\u043e \u0437\u043d\u0430\u0447\u0435\u043d\u0438\u0435. \u041d\u0438\u0435 \u043f\u0440\u0435\u0434\u043b\u0430\u0433\u0430\u043c\u0435 <strong>\u043f\u0440\u043e\u0444\u0435\u0441\u0438\u043e\u043d\u0430\u043b\u043d\u0430 \u0430\u0432\u0442\u043e\u0434\u0438\u0430\u0433\u043d\u043e\u0441\u0442\u0438\u043a\u0430 \u043d\u0430 Volkswagen<\/strong>, \u0438\u0437\u043f\u043e\u043b\u0437\u0432\u0430\u0439\u043a\u0438 \u043f\u043e\u0441\u043b\u0435\u0434\u043d\u043e \u043f\u043e\u043a\u043e\u043b\u0435\u043d\u0438\u0435 \u0442\u0435\u0445\u043d\u043e\u043b\u043e\u0433\u0438\u0438 \u0438 \u043e\u0444\u0438\u0446\u0438\u0430\u043b\u0435\u043d \u0441\u043e\u0444\u0442\u0443\u0435\u0440 \u0437\u0430 \u0434\u0438\u0430\u0433\u043d\u043e\u0441\u0442\u0438\u043a\u0430.<\/p><p>\u0420\u0430\u0431\u043e\u0442\u0438\u043c \u0441 <strong>ODIS<\/strong> \u2013 \u043e\u0444\u0438\u0446\u0438\u0430\u043b\u043d\u0438\u044f \u0441\u043e\u0444\u0442\u0443\u0435\u0440 \u0437\u0430 \u0434\u0438\u0430\u0433\u043d\u043e\u0441\u0442\u0438\u043a\u0430 \u043d\u0430 <strong>Volkswagen<\/strong>, \u043a\u043e\u0439\u0442\u043e \u043d\u0438 \u0434\u0430\u0432\u0430 \u0434\u043e\u0441\u0442\u044a\u043f \u0434\u043e \u0432\u0441\u0438\u0447\u043a\u0438 \u0435\u043b\u0435\u043a\u0442\u0440\u043e\u043d\u043d\u0438 \u043c\u043e\u0434\u0443\u043b\u0438 \u043d\u0430 \u0430\u0432\u0442\u043e\u043c\u043e\u0431\u0438\u043b\u0430. \u0422\u043e\u0432\u0430 \u043f\u043e\u0437\u0432\u043e\u043b\u044f\u0432\u0430 \u043f\u0440\u0435\u0446\u0438\u0437\u043d\u0430 \u0438 \u043f\u044a\u043b\u043d\u0430 \u043f\u0440\u043e\u0432\u0435\u0440\u043a\u0430 \u043d\u0430 \u0432\u0441\u0438\u0447\u043a\u0438 \u0441\u0438\u0441\u0442\u0435\u043c\u0438 \u043d\u0430 \u0430\u0432\u0442\u043e\u043c\u043e\u0431\u0438\u043b\u0430.<\/p><h3>\u041a\u0430\u043a\u0432\u043e \u0432\u043a\u043b\u044e\u0447\u0432\u0430 \u043d\u0430\u0448\u0430\u0442\u0430 \u0443\u0441\u043b\u0443\u0433\u0430 \u0437\u0430 \u0434\u0438\u0430\u0433\u043d\u043e\u0441\u0442\u0438\u043a\u0430 \u043d\u0430 Volkswagen?<\/h3><ol><li><strong>\u041f\u044a\u043b\u043d\u0430 \u043f\u0440\u043e\u0432\u0435\u0440\u043a\u0430 \u043d\u0430 \u0432\u0441\u0438\u0447\u043a\u0438 \u0435\u043b\u0435\u043a\u0442\u0440\u043e\u043d\u043d\u0438 \u0441\u0438\u0441\u0442\u0435\u043c\u0438<\/strong><\/li><li><strong>\u0418\u0434\u0435\u043d\u0442\u0438\u0444\u0438\u0446\u0438\u0440\u0430\u043d\u0435 \u0438 \u0438\u0437\u0447\u0438\u0441\u0442\u0432\u0430\u043d\u0435 \u043d\u0430 \u0433\u0440\u0435\u0448\u043a\u0438<\/strong><\/li><li><strong>\u0410\u0434\u0430\u043f\u0442\u0430\u0446\u0438\u044f \u0438 \u043a\u043e\u0434\u0438\u0440\u0430\u043d\u0435 \u043d\u0430 \u043d\u043e\u0432\u0438 \u043c\u043e\u0434\u0443\u043b\u0438<\/strong><\/li><li><strong>\u041f\u0440\u043e\u0432\u0435\u0440\u043a\u0430 \u043d\u0430 \u0440\u0435\u0430\u043b\u043d\u0438 \u043a\u0438\u043b\u043e\u043c\u0435\u0442\u0440\u0438<\/strong><\/li><li><strong>\u0410\u0432\u0442\u043e\u0434\u0438\u0430\u0433\u043d\u043e\u0441\u0442\u0438\u043a\u0430 \u043d\u0430 \u0445\u0438\u0431\u0440\u0438\u0434\u043d\u0438 \u0438 \u0435\u043b\u0435\u043a\u0442\u0440\u0438\u0447\u0435\u0441\u043a\u0438 \u043c\u043e\u0434\u0435\u043b\u0438 Volkswagen<\/strong><\/li><\/ol><h3>\u0417\u0430\u0449\u043e \u0434\u0430 \u0438\u0437\u0431\u0435\u0440\u0435\u0442\u0435 Bestdiagnostics \u0437\u0430 \u0434\u0438\u0430\u0433\u043d\u043e\u0441\u0442\u0438\u043a\u0430 \u043d\u0430 <strong>Volkswagen<\/strong>?<\/h3><ul><li>\u041e\u0444\u0438\u0446\u0438\u0430\u043b\u0435\u043d \u0441\u043e\u0444\u0442\u0443\u0435\u0440<\/li><li>\u0413\u0430\u0440\u0430\u043d\u0446\u0438\u044f \u043d\u0430 \u0443\u0441\u043b\u0443\u0433\u0430\u0442\u0430 \u0438 \u0432\u044a\u0437\u043c\u043e\u0436\u043d\u043e\u0441\u0442 \u0437\u0430 \u043f\u043e\u0432\u0442\u043e\u04